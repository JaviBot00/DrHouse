<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <!--    FindPacienteXDNI  -->
    <servlet>
        <servlet-name>FindPacienteXDNI</servlet-name>
        <servlet-class>com.politecnicomalaga.clinica.view.FindPacienteXDNI</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FindPacienteXDNI</servlet-name>
        <url-pattern>/find-paciente</url-pattern>
    </servlet-mapping>

    <!--    FindMedicamentoXCodigo-->
    <servlet>
        <servlet-name>FindMedicamentoXCodigo</servlet-name>
        <servlet-class>com.politecnicomalaga.clinica.view.FindMedicamentoXCodigo</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FindMedicamentoXCodigo</servlet-name>
        <url-pattern>/find-medicamento</url-pattern>
    </servlet-mapping>

    <!--    ImportData-->
    <servlet>
        <servlet-name>ImportData</servlet-name>
        <servlet-class>com.politecnicomalaga.clinica.view.ImportData</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ImportData</servlet-name>
        <url-pattern>/import-data</url-pattern>
    </servlet-mapping>

    <!--    ListAllMedicamentos-->
    <servlet>
        <servlet-name>ListAllMedicamentos</servlet-name>
        <servlet-class>com.politecnicomalaga.clinica.view.ListAllMedicamentos</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListAllMedicamentos</servlet-name>
        <url-pattern>/list-medicamentos</url-pattern>
    </servlet-mapping>

    <!--    ListMedicamentosXTratamiento  -->
    <servlet>
        <servlet-name>ListMedicamentosXTratamiento</servlet-name>
        <servlet-class>com.politecnicomalaga.clinica.view.ListMedicamentosXTratamiento</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListMedicamentosXTratamiento</servlet-name>
        <url-pattern>/list-medicamento-tratamiento</url-pattern>
    </servlet-mapping>
</web-app>
